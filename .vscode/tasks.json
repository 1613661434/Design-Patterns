{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-all",
      "detail": "编译全部 24 个设计模式",
      "type": "shell",
      "windows": {
        "command": "$cats = @('01_创建型模式','02_结构型模式','03_行为模式'); foreach ($c in $cats) { Get-ChildItem $c -Directory | ForEach-Object { Write-Host \"=== $($_.Name) ===\"; make -C $_.FullName -s; if ($LASTEXITCODE -ne 0) { exit 1 } } }; Write-Host '全部编译完成!'"
      },
      "linux": {
        "command": "/bin/sh",
        "args": [
          "-c",
          "for d in 01_创建型模式/*/ 02_结构型模式/*/ 03_行为模式/*/; do echo \"=== $$d ===\"; make -C \"$$d\" -s || exit 1; done && echo '全部编译完成!'"
        ]
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "clean-all",
      "detail": "清理全部编译产物",
      "type": "shell",
      "windows": {
        "command": "$cats = @('01_创建型模式','02_结构型模式','03_行为模式'); foreach ($c in $cats) { Get-ChildItem $c -Directory | ForEach-Object { make -C $_.FullName clean -s 2>$null } }; Write-Host '全部清理完成!'"
      },
      "linux": {
        "command": "/bin/sh",
        "args": [
          "-c",
          "for d in 01_创建型模式/*/ 02_结构型模式/*/ 03_行为模式/*/; do make -C \"$$d\" clean -s 2>/dev/null; done && echo '全部清理完成!'"
        ]
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
